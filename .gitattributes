# Auto detect text files and perform LF normalization
* text=auto

# Exclude from git archive / GitHub zipball.
#
# The updater normally installs the release ASSET built by
# .github/workflows/release-zip.yml, and export-ignore does NOT affect that.
# But get_download_url() falls back to the zipball when a release carries no
# asset (e.g. the build failed), so keep this list in step with the rsync
# --exclude list in that workflow.
/.gitattributes    export-ignore
/.gitignore        export-ignore
/.mailmap          export-ignore
/.github/          export-ignore
/.editorconfig     export-ignore
/.eslintrc.json    export-ignore
/.phpcs.xml.dist   export-ignore
/phpstan.neon.dist export-ignore
/phpunit.xml.dist  export-ignore
/composer.json     export-ignore
/composer.lock     export-ignore
/package.json      export-ignore
/package-lock.json export-ignore
/CHANGELOG.md      export-ignore
/tests/            export-ignore
/build/            export-ignore
/generate_rules.py export-ignore
/woobooster-rules-import.json export-ignore
*.zip              export-ignore
AUDIT_*.md         export-ignore
